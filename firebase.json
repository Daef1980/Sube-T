{
  "functions": {
    "source": "functions",
    "runtime": "nodejs18"
  },
  "firestore": {
    "rules": "firestore.rules",
    "indexes": "firestore.indexes.json"
  },
  "hosting": {
    "public": "public",
    "ignore": ["firebase.json", "**/.*", "**/node_modules/**"],
    "rewrites": [
      {
        "source": "/api/crearPago",
        "function": "crearPago"
      },
      {
        "source": "/api/estadoReserva",
        "function": "estadoReserva"
      }
    ]
  }
}
