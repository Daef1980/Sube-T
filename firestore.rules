rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Reservas: cualquiera puede leer la suya con el folio,
    // solo las Cloud Functions (admin SDK) pueden escribir.
    match /reservas/{folio} {
      allow read: if true;   // el cliente consulta su reserva por folio
      allow write: if false; // solo el backend escribe via Admin SDK
    }

    // Pagos: solo lectura interna (admin)
    match /pagos/{id} {
      allow read, write: if false;
    }

    // Unidades y conductores: solo lectura pública, escritura admin
    match /unidades/{id} {
      allow read: if true;
      allow write: if false;
    }

    match /conductores/{id} {
      allow read: if true;
      allow write: if false;
    }
  }
}
